# Loopback-only development defaults. Set a token before exposing beyond local development.
TEMPLAR_HOST=127.0.0.1
TEMPLAR_PORT=8080
TEMPLAR_HOME=.templar
TEMPLAR_BEARER_TOKEN=
TEMPLAR_MAX_ACTIVE_RUNS=2
TEMPLAR_MAX_JSON_BYTES=65536
TEMPLAR_MAX_PCAP_BYTES=8388608
TEMPLAR_MAX_PCAP_PACKETS=50000
TEMPLAR_MAX_EXERCISE_SNAPSHOT_BYTES=524288
TEMPLAR_MAX_COURSE_LAB_SPECIMEN_BYTES=268435456
TEMPLAR_MAX_SOURCE_SNAPSHOT_BYTES=8388608
# Drone owns sandbox providers and execution. Keep it on loopback for local development.
TEMPLAR_DRONE_ENABLED=true
TEMPLAR_DRONE_URL=http://127.0.0.1:8090
TEMPLAR_DRONE_TOKEN=
TEMPLAR_DRONE_TIMEOUT_MS=1000
TEMPLAR_DRONE_SOURCE_VALIDATION_OPERATION_ID=
TEMPLAR_DRONE_COURSE_LAB_OPERATION_ID=
