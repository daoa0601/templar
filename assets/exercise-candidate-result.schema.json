{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.templar/schemas/exercise-candidate-result.v1.json",
  "title": "Exercise candidate result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "summary",
    "answers",
    "unanswered_question_ids",
    "evidence_checks_relied_on",
    "checks_performed",
    "external_mutations"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "status": { "enum": ["completed", "incomplete"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question_id", "answer", "observation_ids", "uncertainty"],
        "properties": {
          "question_id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "answer": { "type": "string", "minLength": 1, "maxLength": 8000 },
          "observation_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string" }
          },
          "uncertainty": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "unanswered_question_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "evidence_checks_relied_on": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "checks_performed": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "external_mutations": { "type": "array", "maxItems": 0 }
  }
}
