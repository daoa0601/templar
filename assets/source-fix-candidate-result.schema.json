{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.templar/schemas/source-fix-candidate-result.v1.json",
  "title": "Source security fix candidate result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "summary",
    "finding_resolutions",
    "changes",
    "tests",
    "dynamic_validation",
    "promotion",
    "external_mutations"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "status": { "const": "completed" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "finding_resolutions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": { "$ref": "#/$defs/findingResolution" }
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/change" }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": { "$ref": "#/$defs/test" }
    },
    "dynamic_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "job_id"],
      "properties": {
        "status": { "const": "not_run" },
        "job_id": { "type": "null" }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["impact", "security_outcome", "headline_result"],
      "properties": {
        "impact": { "enum": ["routine", "high"] },
        "security_outcome": { "const": true },
        "headline_result": { "const": false }
      }
    },
    "external_mutations": { "type": "array", "maxItems": 0 }
  },
  "$defs": {
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 240 },
        "line": { "type": "integer", "minimum": 1 }
      }
    },
    "findingResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "root_cause",
        "changed_paths",
        "regression_test_paths",
        "variant_locations",
        "residual_risk"
      ],
      "properties": {
        "finding_id": { "type": "string", "pattern": "^FINDING-[0-9]{3,5}$" },
        "root_cause": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "changed_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "regression_test_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        },
        "variant_locations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/location" }
        },
        "residual_risk": { "type": "string", "minLength": 1, "maxLength": 4000 }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "status", "finding_ids", "rationale"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 240 },
        "status": { "enum": ["added", "modified", "deleted"] },
        "finding_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "finding_ids", "expected_behavior"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 240 },
        "finding_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "expected_behavior": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    }
  }
}
